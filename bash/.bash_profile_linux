[[ -f ~/.bashrc ]] && source ~/.bashrc

# ---------------------------------------------------------------------------
# Git shortcuts (complements git aliases in .gitconfig)
# ---------------------------------------------------------------------------
alias g='git'
command -v lazygit &>/dev/null && alias lg='lazygit'

# ---------------------------------------------------------------------------
# Navigation shortcuts
# ---------------------------------------------------------------------------
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
