[alias]
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	co = checkout
	cob = checkout -b
	sw = switch
	swc = switch -c
	wt = worktree
	wta = worktree add
	f = fetch -p
	c = commit
	p = push
	pushf = push --force-with-lease
	st = status
	b = branch -vv
	ba = branch -a
	bd = branch -d
	bD = branch -D
	dc = diff --cached
	undo = reset --soft HEAD~1
	unstage = restore --staged
	amend = commit --amend --no-edit
	aliases = config --get-regexp alias
	root = rev-parse --show-toplevel
	merges = log --oneline --decorate --color=auto --merges --first-parent
	rbi = rebase -i
	rbc = rebase --continue
	rba = rebase --abort
	cp = cherry-pick
	stash-all = stash push --include-untracked
	dbc = difftool -t bc
	mbc = mergetool -t bc

[diff]
	tool = difftastic
	guitool = vscode
	external = difft

[pager]
	# Use a pager if the difftool output is larger than one screenful,
	# consistent with the behaviour of `git diff`.
	difftool = true

[difftool]
	# Run the difftool immediately, don't ask 'are you sure' each time.
	prompt = false

[difftool "difftastic"]
	cmd = difft "$LOCAL" "$REMOTE"

[difftool "vscode"]
	cmd = code --wait --diff "$LOCAL" "$REMOTE"

[difftool "bc"]
	cmd = bcomp "$LOCAL" "$REMOTE"

[merge]
	tool = vscode
	guitool = vscode
	conflictStyle = diff3

[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[mergetool]
	keepBackup = false
	prompt = false

[mergetool "vscode"]
	cmd = code --wait "$MERGED"

[mergetool "bc"]
	cmd = bcomp "$LOCAL" "$REMOTE" "$BASE" "$MERGED"

[core]
	autocrlf = false
	eol = lf
	attributesfile = ~/.gitattributes
	pager = delta

[color]
	ui = auto

[interactive]
	diffFilter = delta --color-only

[delta]
	navigator = true
	light = false
	side-by-side = false
	line-numbers = true

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[init]
	defaultBranch = main

[branch]
	sort = -committerdate

[rerere]
	enabled = true

[include]
	path = ~/.gitconfig.local
